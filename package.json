{
  "name": "ada",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "build:exe": "node scripts/build-executable.mjs",
    "generate:bundled-config": "node scripts/generate-bundled-config.mjs",
    "dev": "npm run --workspace @ada/agent dev",
    "mcp:dev": "npm run --workspace @ada-mcp/mcp-server dev",
    "mcp:check:versions": "node scripts/check-mcp-publish-versions.mjs",
    "mcp:pack:dry-run": "npm run mcp:check:versions && npm --prefix apps/ada-mcp-server run pack:dry-run",
    "mcp": "tsx apps/ada-agent/src/main.ts mcp",
    "setup": "npm run --workspace @ada/agent setup",
    "setup:cli": "tsx apps/ada-agent/src/main.ts setup --mode=cli",
    "setup:gui": "tsx apps/ada-agent/src/main.ts setup --mode=gui",
    "demo": "npm run --workspace @ada/agent demo",
    "start:once": "tsx apps/ada-agent/src/main.ts start --once",
    "start:watch": "tsx apps/ada-agent/src/main.ts start --watch",
    "install:deps": "tsx apps/ada-agent/src/main.ts install-deps",
    "run:tasks": "tsx apps/ada-agent/src/main.ts run --file=tasks/demo.tasks.json",
    "run:web-real": "tsx apps/ada-agent/src/main.ts run --file=tasks/web-real.tasks.json",
    "run:web-real:verify": "tsx apps/ada-agent/src/main.ts run --file=tasks/web-real.tasks.json --verify-artifacts",
    "run:web-real:strict": "tsx apps/ada-agent/src/main.ts run --file=tasks/web-real.tasks.json --require-real --verify-artifacts",
    "run:appium-probe": "tsx apps/ada-agent/src/main.ts run --file=tasks/appium-probe.tasks.json",
    "test:e2e:smoke": "node scripts/e2e-smoke.mjs",
    "test:e2e:smoke:strict": "node scripts/e2e-smoke.mjs --strict",
    "test:e2e:smoke:full": "node scripts/e2e-smoke.mjs --strict",
    "test:entrypoints": "node scripts/verify-entrypoints.mjs",
    "test:conformance": "tsx test/conformance/driver-conformance.ts",
    "health": "tsx apps/ada-agent/src/main.ts health",
    "doctor": "tsx apps/ada-agent/src/main.ts doctor",
    "plugins": "tsx apps/ada-agent/src/main.ts plugins",
    "reset": "tsx apps/ada-agent/src/main.ts reset",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "contracts:schema": "npm run --workspace @ada/contracts schema:generate",
    "contracts:compat": "npm run contracts:schema && npm run --workspace @ada/contracts schema:compat",
    "test:mcp:bundled": "node scripts/mcp-bundled-smoke.mjs",
    "gui:dev": "npm run --workspace @ada/gui tauri:dev",
    "gui:build": "npm run --workspace @ada/gui tauri:build"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "appium-uiautomator2-driver": "^4.2.9",
    "esbuild": "^0.25.11",
    "pkg": "^5.8.1",
    "rcedit": "^5.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "uiautomator2": "^1.0.2"
  },
  "dependencies": {
    "appium": "^3.3.1",
    "playwright": "^1.59.1"
  }
}
