{
  "name": "ada",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "author": "Kalami (卡拉米)",
  "repository": {
    "type": "git",
    "url": "https://github.com/osgm/ada.git"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "build:exe": "node scripts/build/build-executable.mjs",
    "generate:bundled-config": "node scripts/build/generate-bundled-config.mjs",
    "build:executor-dev": "node scripts/build/build-executor-dev.mjs",
    "dev": "npm run --workspace @ada/agent dev",
    "mcp:dev": "npm run --workspace @ada-mcp/mcp-server dev",
    "mcp:check:versions": "node scripts/release/check-mcp-publish-versions.mjs",
    "mcp:preflight": "npm run mcp:check:versions && npm run build:npm -w @ada-mcp/mcp-server && npm run test:verify:mcp-plugins && npm run test:verify:driver-rpc-sync && npm run test:mcp:unit && npm run test:mcp:bridge && npm run test:mcp:bundled",
    "sync:download-probe": "npm run build -w @ada/download-probe && node scripts/build/sync-download-probe-vendor.mjs",
    "sync:log-locale": "node scripts/build/sync-log-locale-vendor.mjs",
    "sync:scripts-lib": "node scripts/build/sync-scripts-lib-from-driver-rpc.mjs",
    "mcp:pack:dry-run": "npm run mcp:check:versions && npm --prefix apps/ada-mcp-server run pack:dry-run",
    "mcp": "tsx apps/ada-agent/src/main.ts mcp",
    "setup": "npm run --workspace @ada/agent setup",
    "setup:cli": "tsx apps/ada-agent/src/main.ts setup --mode=cli",
    "setup:gui": "tsx apps/ada-agent/src/main.ts setup --mode=gui",
    "demo": "npm run --workspace @ada/agent demo",
    "start:once": "tsx apps/ada-agent/src/main.ts start --once",
    "start:watch": "tsx apps/ada-agent/src/main.ts start --watch",
    "install:deps": "tsx apps/ada-agent/src/main.ts install-deps",
    "run:tasks": "tsx apps/ada-agent/src/main.ts run --file=tasks/demo.tasks.json",
    "run:web-real": "tsx apps/ada-agent/src/main.ts run --file=tasks/web-real.tasks.json",
    "run:web-real:verify": "tsx apps/ada-agent/src/main.ts run --file=tasks/web-real.tasks.json --verify-artifacts",
    "run:web-real:strict": "tsx apps/ada-agent/src/main.ts run --file=tasks/web-real.tasks.json --require-real --verify-artifacts",
    "test:e2e:smoke": "node scripts/test/e2e-smoke.mjs",
    "test:e2e:smoke:strict": "node scripts/test/e2e-smoke.mjs --strict",
    "test:e2e:smoke:mobile": "node scripts/test/e2e-smoke.mjs --mobile",
    "test:e2e:smoke:mobile:strict": "node scripts/test/e2e-smoke.mjs --mobile --mobile-strict",
    "test:e2e:smoke:full": "node scripts/test/e2e-smoke.mjs --strict --mobile",
    "test:entrypoints": "node scripts/test/verify-entrypoints.mjs",
    "test:conformance": "tsx test/conformance/driver-conformance.ts",
    "test:unit": "node scripts/test/run-node-tests.mjs unit",
    "test:mcp:unit": "node scripts/test/run-node-tests.mjs mcp",
    "test:mcp:bridge": "tsx test/ada-mcp-bridge.test.ts",
    "test:verify:mcp-plugins": "node scripts/test/verify-mcp-plugins.mjs",
    "test:verify:driver-rpc-sync": "node scripts/test/verify-driver-rpc-bundle-sync.mjs",
    "test:jd-web:mcp:py": "python scripts/examples/python/web/jd_mcp_web.py",
    "test:jd-ios": "node scripts/lib/run-ada-example.mjs scripts/examples/nodejs/ios/jd-e2e.mjs",
    "test:jd-ios:mcp": "node scripts/examples/nodejs/ios/jd-mcp-ios.mjs",
    "test:jd-ios:mcp:py": "python scripts/examples/python/ios/jd_mcp_ios.py",
    "test:jd-ios:py": "python scripts/examples/python/ios/jd_e2e.py",
    "test": "npm run test:unit && npm run test:mcp:unit && npm run test:conformance && npm run test:entrypoints -- --if-present",
    "test:jd-web": "node scripts/lib/run-ada-example.mjs scripts/examples/nodejs/web/jd-e2e.mjs",
    "test:jd-web:mcp": "node scripts/examples/nodejs/web/jd-mcp-web.mjs",
    "test:jd-android": "node scripts/lib/run-ada-example.mjs scripts/examples/nodejs/android/jd-e2e.mjs",
    "test:jd-android:mcp": "node scripts/examples/nodejs/android/jd-mcp-android.mjs",
    "test:jd-harmony": "node scripts/lib/run-ada-example.mjs scripts/examples/nodejs/harmony/jd-e2e.mjs",
    "test:jd-harmony:mcp": "node scripts/examples/nodejs/harmony/jd-mcp-harmony.mjs",
    "test:jd-web:py": "python scripts/examples/python/web/jd_e2e.py",
    "test:jd-android:py": "python scripts/examples/python/android/jd_e2e.py",
    "test:jd-android:mcp:py": "python scripts/examples/python/android/jd_mcp_android.py",
    "test:jd-harmony:py": "python scripts/examples/python/harmony/jd_e2e.py",
    "test:jd-harmony:mcp:py": "python scripts/examples/python/harmony/jd_mcp_harmony.py",
    "health": "tsx apps/ada-agent/src/main.ts health",
    "doctor": "tsx apps/ada-agent/src/main.ts doctor",
    "plugins": "tsx apps/ada-agent/src/main.ts plugins",
    "reset": "tsx apps/ada-agent/src/main.ts reset",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "contracts:schema": "npm run --workspace @ada/contracts schema:generate",
    "contracts:compat": "npm run contracts:schema && npm run --workspace @ada/contracts schema:compat",
    "test:mcp:bundled": "node scripts/release/mcp-bundled-smoke.mjs",
    "gui:dev": "npm run --workspace @ada/gui tauri:dev",
    "gui:build": "npm run --workspace @ada/gui tauri:build"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.11",
    "pkg": "^5.8.1",
    "rcedit": "^5.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  }
}
