  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "maxNodeModuleJsDepth": 0,
    "types": ["node"]
  },
  "include": ["**/*.mjs", "examples/**/*.mjs", "lib/**/*.d.ts"],
  "exclude": ["**/node_modules/**"]
}
