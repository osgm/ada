{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ada/contracts/event-envelope.schema.json",
  "title": "EventEnvelope",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "timestamp"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "requestId": {
      "type": "string"
    },
    "sessionId": {
      "type": "string"
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
