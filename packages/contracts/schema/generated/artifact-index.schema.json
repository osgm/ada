{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ada/contracts/artifact-index.schema.json",
  "title": "ArtifactIndex",
  "type": "object",
  "required": [
    "requestId",
    "items"
  ],
  "properties": {
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "screenshot",
              "video",
              "pageSource",
              "log"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "mimeType": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
