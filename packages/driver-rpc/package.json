      "default": "./src/normalize-command.ts"
    }
  },
  "files": ["src", "dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ada/contracts": "0.1.0",
    "@ada/core-runtime": "0.1.0",
    "@ada/mobile-ui": "0.1.0"
  }
