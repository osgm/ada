{
  "mcpServers": {
    "ada-mcp": {
      "command": "pnpm",
      "args": [
        "dlx",
        "@ada-mcp/launcher@0.1.49",
        "--skip-install-deps"
      ],
      "env": {
        "ADA_MCP_SKIP_INSTALL_DEPS": "1",
        "ADA_MCP_SKIP_REGISTRY_PROBE": "1",
        "ADA_MCP_REGISTRY": "https://registry.npmmirror.com",
        "ADA_PLAYWRIGHT_HEADLESS": "true"
      }
    }
  }
}