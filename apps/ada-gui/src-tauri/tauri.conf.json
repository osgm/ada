{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADA GUI",
  "version": "0.1.0",
  "identifier": "com.ada.gui",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @ada/gui",
    "beforeBuildCommand": "npm run build --workspace @ada/gui",
    "devUrl": "http://localhost:17660",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ADA GUI",
        "width": 1080,
        "height": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
